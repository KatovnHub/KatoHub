-- ================== FUNCTIONS (Giữ nguyên từ bản gốc) ==================
local function isAmmoRelated(name)
    local lower = name:lower()
    local patterns = {"ammo", "clip", "magazine", "mag", "bullet", "round", "current"}
    for _, pat in ipairs(patterns) do
        if lower:find(pat) then return true end
    end
    return false
end

local function isReserveRelated(name)
    local lower = name:lower()
    return lower:find("reserve") or lower:find("stock") or lower:find("total")
end

local function applyModifier(obj)
    local lower = obj.Name:lower()
    if lower:find("recoil") or lower:find("spread") or lower:find("sway") or lower:find("bloom") then
        obj.Value = 0
    elseif lower:find("firerate") or lower:find("rof") then
        obj.Value = math.max(obj.Value or 100, 1000)
    elseif lower:find("delay") or lower:find("cooldown") then
        obj.Value = 0.01
    end
end

local function ModifyAmmo(tool)
    pcall(function()
        for _, obj in pairs(tool:GetDescendants()) do
            if obj:IsA("IntValue") or obj:IsA("NumberValue") then
                local name = obj.Name
                if isAmmoRelated(name) then
                    obj.Value = Settings.AmmoAmount + math.random(-2, 2)
                elseif isReserveRelated(name) then
                    obj.Value = Settings.ReserveAmount + math.random(-10, 10)
                end
            end
        end
        if Settings.Modifiers then
            for _, obj in pairs(tool:GetDescendants()) do
                if obj:IsA("IntValue") or obj:IsA("NumberValue") then
                    applyModifier(obj)
                end
            end
        end
    end)
end

-- ================== MAIN LOOP ==================
local HeartbeatConnection

local function StartLoop()
    if HeartbeatConnection then HeartbeatConnection:Disconnect() end
    HeartbeatConnection = RunService.Heartbeat:Connect(function()
        if not Settings.Enabled then return end
        
        local char = LocalPlayer.Character
        if char then
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then ModifyAmmo(tool) end
        end
        
        for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
            if tool:IsA("Tool") then ModifyAmmo(tool) end
        end
    end)
end

local function StopLoop()
    if HeartbeatConnection then
        HeartbeatConnection:Disconnect()
        HeartbeatConnection = nil
    end
end

-- ================== TOGGLE ==================
local function Toggle()
    Settings.Enabled = not Settings.Enabled
    if Settings.Enabled then
        StartLoop()
        StatusLabel.Text = "Status: ON (INF)"
        StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        print("🟢 Infinite Ammo v7 ENABLED")
    else
        StopLoop()
        StatusLabel.Text = "Status: OFF"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        print("🔴 Infinite Ammo v7 DISABLED")
    end
end

ToggleButton.MouseButton1Click:Connect(Toggle)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        Toggle()
    end
end)

